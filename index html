<div id="direction">

WAIT

</div>

</div>
let currentDirection = "";

function startFlash(){

let dirs =
["↑","↓","←","→"];

currentDirection =
dirs[
Math.floor(
Math.random()*4
)
];

document.getElementById(
"direction"
).innerHTML =
currentDirection;
}
<button onclick="pressDir('↑')">↑</button>

<button onclick="pressDir('↓')">↓</button>

<button onclick="pressDir('←')">←</button>

<button onclick="pressDir('→')">→</button>
let combo = 0;

function pressDir(dir){

if(dir===currentDirection){

combo++;

player.mastery++;

if(combo>=10){

log("BLACK FLASH!");

player.xp+=100;

combo=0;
}

startFlash();

}else{

combo=0;

log("Miss");
}
}
const bosses = [

{
name:"Finger Bearer",
level:25
},

{
name:"Special Grade Curse",
level:50
},

{
name:"Disaster Curse",
level:100
}

];
function checkBoss(){

for(let boss of bosses){

if(player.level===boss.level){

log(
boss.name +
" appeared!"
);
}
}
